# AI LEARNING ASSISTANT - ENVIRONMENT TEMPLATE
# Hướng dẫn: Copy file này thành file '.env' và điền các giá trị thực tế của bạn.

# SERVER CONFIG
PORT=8000
ENV=development
# Ví dụ: http://localhost:5500,http://127.0.0.1:5500
CORS_ALLOWED_ORIGINS=

# OPENAI CONFIG
# Lấy key tại: https://platform.openai.com/
OPENAI_SECRET_KEY = "your-openai-secret-key-here"
OPENAI_MODEL_NAME=gpt-4o-mini

# DATABASE & RAG
# SQLite: sqlite:///./learning_assistant.db
# PostgreSQL: postgresql://user:password@localhost/dbname
DATABASE_URL=sqlite:///./learning_assistant.db

# Vector Database (Nếu dùng Pinecone)
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=

# SECURITY & AUTH
# Tạo key bằng lệnh: openssl rand -hex 32
JWT_SECRET_KEY=your_secret_key_for_jwt_tokens
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440